{
  "name": "duckcode",
  "version": "0.1.7",
  "description": "AI coding agent for your terminal — self-hosted, works with any OpenAI-compatible backend",
  "type": "module",
  "bin": {
    "duckcode": "dist/main.js",
    "duck": "dist/main.js"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE",
    "DUCK.md.example"
  ],
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "cli",
    "llm",
    "openai",
    "self-hosted",
    "terminal",
    "developer-tools",
    "mcp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/simonlemon333/duckcode.git"
  },
  "author": "Simon <simonlemon333@users.noreply.github.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^11.0.0",
    "undici": "^7.24.7"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
